// ============================================================
// Prisma Schema — Omni Social Manager
// Supports: Facebook, Zalo OA, TikTok, Web Live Chat
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────
// ENUMS (stored as plain strings in SQLite)
// ──────────────────────────────────────────────────────────────
// Role       : ADMIN | SUPPORTER
// Platform   : FACEBOOK | ZALO | TIKTOK | WEB
// ConvStatus : OPEN | RESOLVED | PENDING
// SenderType : CUSTOMER | STAFF | BOT

// ──────────────────────────────────────────────────────────────
// USER  — staff members with RBAC
// ──────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String   // bcrypt hash
  displayName  String
  avatarUrl    String?
  role         String   @default("SUPPORTER") // "ADMIN" | "SUPPORTER"
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  assignedConversations Conversation[] @relation("AssignedTo")
  messages              Message[]      @relation("SentBy")
  channelAccess         UserChannel[]

  @@index([role, isActive])
}

// ──────────────────────────────────────────────────────────────
// CHANNEL  — one row per communication node (up to 12)
// ──────────────────────────────────────────────────────────────
model Channel {
  id           String   @id @default(cuid())
  platform     String   // "FACEBOOK" | "ZALO" | "TIKTOK" | "WEB"
  accountId    String   // Platform-specific page/OA/profile ID
  name         String   // Human-readable: "Thắng Tin Học - FB Page 1"
  accessToken  String?  // AES-256 encrypted at rest
  refreshToken String?  // AES-256 encrypted at rest
  appId        String?  // OAuth App ID
  appSecret    String?  // AES-256 encrypted
  webhookSecret String? // HMAC verify secret (FB, Zalo)
  widgetKey    String?  // Web live-chat embed key
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  metadata     String?  // JSON: extra platform config (page name, avatar, follower count…)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  conversations Conversation[]
  userAccess    UserChannel[]

  @@unique([platform, accountId])
  @@index([platform, isActive])
}

// ──────────────────────────────────────────────────────────────
// USER ↔ CHANNEL  — which staff can access which channels
// Admins implicitly get all; Supporters list explicit channels.
// ──────────────────────────────────────────────────────────────
model UserChannel {
  userId    String
  channelId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([userId, channelId])
}

// ──────────────────────────────────────────────────────────────
// CUSTOMER  — CRM entity (deduped across channels)
// ──────────────────────────────────────────────────────────────
model Customer {
  id          String   @id @default(cuid())
  fullName    String
  phone       String?  @unique
  email       String?  @unique
  avatarUrl   String?
  notes       String?  // Internal CRM notes
  tags        String   @default("[]") // JSON string[]
  source      String?  // First channel they contacted from
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversations Conversation[]

  @@index([phone])
  @@index([email])
}

// ──────────────────────────────────────────────────────────────
// CONVERSATION  — thread linking Customer ↔ Channel
// ──────────────────────────────────────────────────────────────
model Conversation {
  id               String    @id @default(cuid())
  channelId        String
  channel          Channel   @relation(fields: [channelId], references: [id])
  customerId       String?
  customer         Customer? @relation(fields: [customerId], references: [id])
  externalId       String    // Platform thread ID (e.g. FB PSID, Zalo user ID)
  participantName  String    // Display name at time of first contact
  participantPhone String?
  status           String    @default("OPEN") // "OPEN" | "RESOLVED" | "PENDING"
  assignedToUserId String?
  assignedTo       User?     @relation("AssignedTo", fields: [assignedToUserId], references: [id])
  lastMessage      String?
  lastMessageAt    DateTime?
  unreadCount      Int       @default(0)
  isArchived       Boolean   @default(false)
  metadata         String?   // JSON: platform-specific extras
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  messages Message[]

  @@unique([channelId, externalId])
  @@index([channelId, status, lastMessageAt])  // Main inbox sort query
  @@index([assignedToUserId, status])           // My conversations filter
  @@index([customerId])                         // CRM: customer history
  @@index([status, isArchived, lastMessageAt])  // Archived view
  @@index([participantPhone])                   // CRM phone lookup
}

// ──────────────────────────────────────────────────────────────
// MESSAGE  — individual messages within a conversation
// ──────────────────────────────────────────────────────────────
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderType     String       // "CUSTOMER" | "STAFF" | "BOT"
  sentByUserId   String?      // Only set when senderType = "STAFF"
  sentBy         User?        @relation("SentBy", fields: [sentByUserId], references: [id])
  externalId     String?      // Platform message ID (for dedup)
  content        String
  mediaUrl       String?
  mediaType      String?      // "image" | "video" | "file" | "audio"
  status         String       @default("delivered") // "sent" | "delivered" | "read" | "failed"
  timestamp      DateTime     @default(now())
  createdAt      DateTime     @default(now())

  @@index([conversationId, timestamp])  // Fast pagination: load last 50 msgs
  @@index([externalId])                  // Deduplication lookup
  @@index([senderType, timestamp])       // Analytics: filter by sender type
  @@index([status])                      // Filter failed messages
}

// ──────────────────────────────────────────────────────────────
// SCHEDULED POST  — cross-channel publishing queue
// ──────────────────────────────────────────────────────────────
model ScheduledPost {
  id            String   @id @default(cuid())
  channelIds    String   // JSON: Channel.id[]  — target channels
  caption       String
  captionFb     String?
  captionZalo   String?
  captionTiktok String?
  captionWeb    String?
  mediaUrls     String?  // JSON: file paths[]
  mediaType     String?  // "image" | "video" | "carousel"
  scheduledAt   DateTime
  status        String   @default("pending") // "pending" | "publishing" | "published" | "failed"
  publishResults String? // JSON: per-channel results
  errorLog      String?
  createdByUserId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, scheduledAt])
}

// ──────────────────────────────────────────────────────────────
// QUICK REPLY TEMPLATE
// ──────────────────────────────────────────────────────────────
model QuickReply {
  id        String   @id @default(cuid())
  command   String   @unique // "/baogia"
  label     String
  category  String   @default("general")
  content   String
  channelIds String  @default("[]") // JSON: Channel.id[] — empty = all channels
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────
// APP SETTING  — key/value store
// ──────────────────────────────────────────────────────────────
model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
